{
  "name": "@gp2f/server",
  "version": "0.1.0",
  "description": "Native Node.js bindings for the GP2F policy engine – powered by napi-rs",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "index.d.ts",
    "gp2f_node.*.node"
  ],
  "scripts": {
    "build": "cargo build --release",
    "build:debug": "cargo build",
    "test": "jest --passWithNoTests"
  },
  "keywords": ["gp2f", "policy", "workflow", "napi", "native"],
  "license": "MIT",
  "napi": {
    "name": "gp2f-node",
    "triples": {
      "defaults": true,
      "additional": [
        "x86_64-unknown-linux-musl",
        "aarch64-unknown-linux-gnu",
        "aarch64-apple-darwin"
      ]
    }
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "jest": "^29.0.0"
  },
  "engines": {
    "node": ">= 16"
  }
}
